# Copy to /etc/insurance-intel.env on the Hetzner VPS, chmod 640, chown root:insurance-intel.
# All variables required unless marked optional.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# Higher token budgets for structuring longer articles. Adjust if cost gets out of hand.
ANTHROPIC_MAX_OUTPUT_TOKENS=2048

# --- Nimble ---
NIMBLE_API_KEY=...
# Optional: override Nimble CLI path if not in default PATH
# NIMBLE_BIN=/usr/local/bin/nimble

# --- Postgres ---
POSTGRES_DSN=postgresql://insurance_intel:STRONG_PW@localhost:5432/insurance_intel

# --- Notifier (ntfy.sh) ---
# Public topic: https://ntfy.sh/<unique-topic>  — subscribe in the ntfy mobile app or web client.
# Self-hosted example: https://ntfy.example.com/insurance-intel
NTFY_TOPIC_URL=https://ntfy.sh/CHANGE-ME-TO-PRIVATE-TOPIC

# --- Git ---
GIT_REPO_DIR=/home/insurance-intel/insurance-intel
# Whether to git commit & push after each run (true on prod, false in dev)
GIT_AUTOPUSH=true

# --- Loop behaviour ---
# Min number of unique events required to mark a run as "succeeded"; below that it's "partial"
MIN_EVENTS_FOR_SUCCESS=1
# How far back to look on the first ever run (no prior loop_runs row)
COLDSTART_LOOKBACK_DAYS=14
# Default per-source max_results in Nimble search
NIMBLE_MAX_RESULTS=10

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=/var/log/insurance-intel/loop.log
